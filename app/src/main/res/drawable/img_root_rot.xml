<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="45"
                android:endColor="#4E342E"
                android:startColor="#8D6E63" />
        </shape>
    </item>
    <item android:bottom="60dp" android:left="40dp" android:right="100dp" android:top="100dp">
        <shape android:shape="oval">
            <solid android:color="#FFCA28" />
        </shape>
    </item>
</layer-list>
