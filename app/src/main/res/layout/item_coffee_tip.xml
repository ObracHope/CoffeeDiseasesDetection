<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardTipRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginEnd="12dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardCornerRadius="18dp"
    app:cardElevation="8dp"
    app:strokeWidth="0dp">

    <FrameLayout
        android:id="@+id/flTipImageContainer"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dashboard_tip_image_height">

        <ImageView
            android:id="@+id/ivTipImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/coffee_care_title"
            android:scaleType="centerCrop"
            android:src="@drawable/photo_healthy_coffee" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_tip_title_overlay" />

        <ImageView
            android:id="@+id/ivTipInfo"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_gravity="end|top"
            android:layout_margin="10dp"
            android:background="@drawable/bg_circle"
            android:backgroundTint="#66FFFFFF"
            android:contentDescription="@string/more_info"
            android:padding="5dp"
            android:src="@android:drawable/ic_dialog_info"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/tvTipTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:paddingHorizontal="14dp"
            android:paddingBottom="18dp"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold" />
    </FrameLayout>
</com.google.android.material.card.MaterialCardView>
