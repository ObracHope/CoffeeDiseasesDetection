<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"

    xmlns:app="http://schemas.android.com/apk/res-auto"

    xmlns:tools="http://schemas.android.com/tools"

    android:layout_width="0dp"

    android:layout_height="wrap_content"

    android:layout_margin="4dp"

    android:clickable="true"

    android:focusable="true"

    android:foreground="?attr/selectableItemBackground"

    app:cardBackgroundColor="@color/white"

    app:cardCornerRadius="12dp"

    app:cardElevation="3dp"

    app:strokeColor="#E8ECE8"

    app:strokeWidth="1dp">



    <LinearLayout

        android:layout_width="match_parent"

        android:layout_height="wrap_content"

        android:gravity="center_horizontal"

        android:minHeight="84dp"

        android:orientation="vertical"

        android:paddingHorizontal="6dp"

        android:paddingVertical="10dp">



        <FrameLayout

            android:id="@+id/flStatIconBg"

            android:layout_width="30dp"

            android:layout_height="30dp"

            android:background="@drawable/bg_circle">



            <ImageView

                android:id="@+id/ivStatIcon"

                android:layout_width="18dp"

                android:layout_height="18dp"

                android:layout_gravity="center"

                android:contentDescription="@null"

                tools:src="@drawable/ic_person_custom" />

        </FrameLayout>



        <TextView

            android:id="@+id/tvStatEmoji"

            android:layout_width="0dp"

            android:layout_height="0dp"

            android:visibility="gone" />



        <TextView

            android:id="@+id/tvOverviewValue"

            android:layout_width="wrap_content"

            android:layout_height="wrap_content"

            android:layout_marginTop="4dp"

            android:textColor="@color/headerDarkGreen"

            android:textSize="18sp"

            android:textStyle="bold"

            tools:text="11" />



        <TextView

            android:id="@+id/tvOverviewLabel"

            android:layout_width="wrap_content"

            android:layout_height="wrap_content"

            android:layout_marginTop="2dp"

            android:gravity="center"

            android:maxLines="2"

            android:textColor="@color/textLight"

            android:textSize="10sp"

            tools:text="Users" />



        <TextView

            android:id="@+id/tvOverviewSubtitle"

            android:layout_width="wrap_content"

            android:layout_height="wrap_content"

            android:visibility="gone" />



        <FrameLayout

            android:id="@+id/flIconBg"

            android:layout_width="0dp"

            android:layout_height="0dp"

            android:visibility="gone">



            <ImageView

                android:id="@+id/ivOverviewIcon"

                android:layout_width="0dp"

                android:layout_height="0dp"

                android:visibility="gone" />

        </FrameLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>

