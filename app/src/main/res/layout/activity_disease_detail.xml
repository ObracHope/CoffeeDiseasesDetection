<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundCream">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primaryGreen"
            app:titleTextColor="@color/white"
            app:navigationIcon="@drawable/ic_back_white"
            app:title="Disease Details" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Disease Image Header -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp">

                <ImageView
                    android:id="@+id/ivDiseaseImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/coffee_leaf_sample"
                    android:contentDescription="Disease affected leaf" />

            </com.google.android.material.card.MaterialCardView>

            <!-- Disease Name Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvDiseaseName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Coffee Leaf Rust"
                        android:textColor="@color/textDark"
                        android:textSize="24sp"
                        android:textStyle="bold"
                         />

                    <TextView
                        android:id="@+id/tvScientificName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hemileia vastatrix"
                        android:textColor="@color/textMedium"
                        android:textSize="14sp"
                        android:layout_marginTop="4dp"
                                                android:fontStyle="italic" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Severity"
                                android:textColor="@color/textMedium"
                                android:textSize="12sp"
                                 />

                            <TextView
                                android:id="@+id/tvSeverity"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="High"
                                android:textColor="@color/status_danger"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp"
                                 />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Spread Rate"
                                android:textColor="@color/textMedium"
                                android:textSize="12sp"
                                 />

                            <TextView
                                android:id="@+id/tvSpreadRate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Fast"
                                android:textColor="@color/status_warning"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp"
                                 />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Symptoms Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="20dp"
                            android:background="@color/primaryGreen"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Symptoms"
                            android:textColor="@color/textDark"
                            android:textSize="18sp"
                            android:textStyle="bold"
                             />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvSymptoms"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="• Orange-yellow powdery spots on leaf undersides\n• Brown lesions on upper leaf surface\n• Premature leaf drop\n• Reduced photosynthesis"
                        android:textColor="@color/textMedium"
                        android:textSize="14sp"
                        android:lineSpacingExtra="4dp"
                         />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Causes Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="20dp"
                            android:background="@color/primaryBrown"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Causes"
                            android:textColor="@color/textDark"
                            android:textSize="18sp"
                            android:textStyle="bold"
                             />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvCauses"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="• Fungal pathogen Hemileia vastatrix\n• High humidity and rainfall\n• Poor air circulation\n• Overcrowding of plants"
                        android:textColor="@color/textMedium"
                        android:textSize="14sp"
                        android:lineSpacingExtra="4dp"
                         />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Prevention Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="20dp"
                            android:background="@color/status_healthy"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Prevention"
                            android:textColor="@color/textDark"
                            android:textSize="18sp"
                            android:textStyle="bold"
                             />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvPrevention"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="• Plant resistant varieties\n• Maintain proper spacing\n• Ensure good drainage\n• Regular monitoring"
                        android:textColor="@color/textMedium"
                        android:textSize="14sp"
                        android:lineSpacingExtra="4dp"
                         />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Treatment Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="20dp"
                            android:background="@color/accentYellow"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Treatment"
                            android:textColor="@color/textDark"
                            android:textSize="18sp"
                            android:textStyle="bold"
                             />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvTreatment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="• Apply copper-based fungicides\n• Remove infected leaves\n• Improve air circulation\n• Adjust irrigation practices"
                        android:textColor="@color/textMedium"
                        android:textSize="14sp"
                        android:lineSpacingExtra="4dp"
                         />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Recommendations Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/primaryGreen">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_dialog_info"
                            app:tint="@color/white"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Expert Recommendations"
                            android:textColor="@color/white"
                            android:textSize="18sp"
                            android:textStyle="bold"
                             />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvRecommendations"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Consult agricultural extension services for specific treatment plans. Early detection and intervention are crucial for preventing spread to neighboring farms."
                        android:textColor="#E8F5E9"
                        android:textSize="14sp"
                        android:lineSpacingExtra="4dp"
                         />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Action Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnScanAgain"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:text="Scan Another Leaf"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:backgroundTint="@color/primaryGreen"
                 />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
