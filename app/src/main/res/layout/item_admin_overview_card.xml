<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:strokeColor="#E8ECE8"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:id="@+id/flIconBg"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_circle">

                <ImageView
                    android:id="@+id/ivOverviewIcon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    app:tint="@color/white"
                    tools:src="@drawable/ic_history_custom" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvOverviewLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:textColor="@color/textMedium"
                android:textSize="13sp"
                tools:text="Total Farmers" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvOverviewValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/headerDarkGreen"
            android:textSize="28sp"
            android:textStyle="bold"
            tools:text="18" />

        <TextView
            android:id="@+id/tvOverviewSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/textLight"
            android:textSize="11sp"
            tools:text="Registered accounts" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
