<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout_admin"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_parchment"
    tools:context=".AdminDashboardActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- 1. Header Section with Curved Background -->
        <View
            android:id="@+id/header_view"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="@drawable/bg_header_curved"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/ivMenuAdmin"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_menu_custom"
            app:tint="@color/white"
            android:padding="12dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="40dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <!-- Profile / Header Circle -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivAdminProfile"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="20dp"
            android:scaleType="centerCrop"
            android:src="@drawable/placeholder_user"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/ivMenuAdmin"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
            app:strokeColor="@color/white"
            app:strokeWidth="2dp"/>

        <!-- Global Search -->
        <ImageView
            android:id="@+id/btnHeaderSearch"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="4dp"
            android:contentDescription="@string/admin_global_search"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_search"
            app:layout_constraintEnd_toStartOf="@id/btnHeaderNotification"
            app:layout_constraintTop_toTopOf="@id/ivAdminProfile"
            app:tint="@color/white" />

        <!-- Notification Bell with Badge -->
        <FrameLayout
            android:id="@+id/btnHeaderNotification"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="12dp"
            app:layout_constraintEnd_toStartOf="@id/ivAdminProfile"
            app:layout_constraintTop_toTopOf="@id/ivAdminProfile">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_notification_custom"
                app:tint="@color/white"
                android:padding="12dp" />

            <TextView
                android:id="@+id/tvNotificationCount"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:background="@drawable/bg_circle"
                android:backgroundTint="#FF3D00"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:gravity="center"
                android:text="0"
                android:visibility="gone"
                android:layout_gravity="top|end"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="8dp" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvAppTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin Dashboard"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/ivMenuAdmin"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp" />

        <!-- Admin Name (hidden, used for data) -->
        <TextView
            android:id="@+id/tvAdminName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            tools:visibility="gone" />

        <!-- 2. Fragment Container for Content -->
        <FrameLayout
            android:id="@+id/fragment_container"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="80dp"
            app:layout_constraintTop_toBottomOf="@id/header_view"
            app:layout_constraintBottom_toTopOf="@id/bottom_nav_card"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 3. Modern Floating Bottom Navigation -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/bottom_nav_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="28dp"
            app:cardElevation="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.bottomnavigation.BottomNavigationView
                android:id="@+id/bottom_navigation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                app:elevation="0dp"
                app:labelVisibilityMode="labeled"
                app:itemIconTint="@color/primaryBrown"
                app:itemTextColor="@color/primaryGreen"
                app:menu="@menu/bottom_nav_admin_menu" />
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 4. Side Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_drawer_admin"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/white"
        app:headerLayout="@layout/fragment_profile"
        app:itemIconTint="@color/primaryBrown"
        app:itemTextColor="#424242"
        app:menu="@menu/drawer_menu_admin" />

</androidx.drawerlayout.widget.DrawerLayout>
