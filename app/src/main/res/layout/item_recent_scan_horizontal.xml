<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"

    xmlns:app="http://schemas.android.com/apk/res-auto"

    xmlns:tools="http://schemas.android.com/tools"

    android:layout_width="140dp"

    android:layout_height="wrap_content"

    android:layout_marginEnd="12dp"

    app:cardBackgroundColor="@color/white"

    app:cardCornerRadius="12dp"

    app:cardElevation="3dp"

    app:strokeColor="#E8ECE8"

    app:strokeWidth="1dp">



    <LinearLayout

        android:layout_width="match_parent"

        android:layout_height="wrap_content"

        android:gravity="center_horizontal"

        android:orientation="vertical"

        android:padding="10dp">



        <com.google.android.material.imageview.ShapeableImageView

            android:id="@+id/ivScanThumb"

            android:layout_width="72dp"

            android:layout_height="72dp"

            android:scaleType="centerCrop"

            android:src="@drawable/img_healthy_leaf"

            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium"

            app:strokeColor="#E0E0E0"

            app:strokeWidth="1dp" />



        <TextView

            android:id="@+id/tvScanEmoji"

            android:layout_width="0dp"

            android:layout_height="0dp"

            android:visibility="gone" />



        <TextView

            android:id="@+id/tvScanDisease"

            android:layout_width="wrap_content"

            android:layout_height="wrap_content"

            android:layout_marginTop="6dp"

            android:gravity="center"

            android:maxLines="2"

            android:textColor="@color/textDark"

            android:textSize="13sp"

            android:textStyle="bold"

            tools:text="Healthy" />



        <TextView

            android:id="@+id/tvScanConfidence"

            android:layout_width="wrap_content"

            android:layout_height="wrap_content"

            android:layout_marginTop="4dp"

            android:textColor="@color/status_healthy"

            android:textSize="12sp"

            android:textStyle="bold"

            tools:text="97%" />



        <TextView

            android:id="@+id/tvScanWhen"

            android:layout_width="wrap_content"

            android:layout_height="wrap_content"

            android:layout_marginTop="4dp"

            android:textColor="@color/textLight"

            android:textSize="10sp"

            tools:text="Today" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>

