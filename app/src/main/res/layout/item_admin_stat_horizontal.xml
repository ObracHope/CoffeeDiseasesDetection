<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="118dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="10dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="14dp"
    app:cardElevation="4dp"
    app:strokeColor="#E8ECE8"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="10dp"
        android:paddingVertical="12dp">

        <FrameLayout
            android:id="@+id/flIconBg"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_circle">

            <ImageView
                android:id="@+id/ivOverviewIcon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                app:tint="@color/white"
                tools:src="@drawable/ic_history_custom" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvOverviewValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/headerDarkGreen"
            android:textSize="22sp"
            android:textStyle="bold"
            tools:text="11" />

        <TextView
            android:id="@+id/tvOverviewLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="center"
            android:maxLines="1"
            android:textColor="@color/textMedium"
            android:textSize="11sp"
            tools:text="Users" />

        <TextView
            android:id="@+id/tvOverviewSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:gravity="center"
            android:maxLines="1"
            android:textColor="@color/textLight"
            android:textSize="9sp"
            android:visibility="gone"
            tools:text="Registered" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
