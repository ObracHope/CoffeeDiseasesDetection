    <!-- Disease names & details -->
    <string name="disease_healthy_name">Kahawa yenye Afya</string>
    <string name="disease_rust_name">Kutu ya Majani ya Kahawa</string>
    <string name="disease_berry_name">Ugonjwa wa Beri ya Kahawa</string>
    <string name="disease_wilt_name">Mnyauko wa Kahawa</string>
    <string name="disease_leaf_miner_name">Mdudu Mchimbaji</string>
    <string name="disease_root_rot_name">Oza ya Mizizi</string>
    <string name="disease_healthy_desc">Mmea wa kahawa uko katika hali nzuri ya afya.</string>
    <string name="disease_rust_desc">Kutu ya majani ni ugonjwa wa fangasi unaoharibu majani.</string>
    <string name="disease_berry_desc">Ugonjwa wa beri huathiri matunda ya kahawa moja kwa moja.</string>
    <string name="disease_wilt_desc">Mnyauko wa kahawa husababisha mmea kukauka na kufa.</string>
    <string name="disease_leaf_miner_desc">Mdudu mchimbaji huharibu tishu za ndani ya jani.</string>
    <string name="disease_root_rot_desc">Oza ya mizizi husababishwa na unyevu mwingi au fangasi wa udongo.</string>
    <string name="disease_healthy_symptoms">Majani ya kijani kibichi, hakuna madoa, mmea una nguvu.</string>
    <string name="disease_rust_symptoms">Madoa ya njano/machungwa chini ya jani.</string>
    <string name="disease_berry_symptoms">Madoa meusi kwenye beri; beri zinaweza kukauka.</string>
    <string name="disease_wilt_symptoms">Majani kunyauka haraka; mmea unakunja.</string>
    <string name="disease_leaf_miner_symptoms">Mistari meupe zenye umbo la zigzag kwenye jani.</string>
    <string name="disease_root_rot_symptoms">Majani kugeuka njano licha ya maji; mmea kudumaa.</string>
    <string name="disease_healthy_treatment">Endelea utunzaji bora: pumua, mbolea, na ukaguzi wa kila siku.</string>
    <string name="disease_rust_treatment">Tumia dawa za fangasi za shaba, ondoa majani yaliyoathirika.</string>
    <string name="disease_berry_treatment">Ondoa matunda yaliyoathirika; tumia fungicide wakati wa kutoa maua.</string>
    <string name="disease_wilt_treatment">Ng\'oa mimea iliyoathirika; boresha mifereji ya maji.</string>
    <string name="disease_leaf_miner_treatment">Tumia dawa za wadudu; ondoa majani yaliyoathirika sana.</string>
    <string name="disease_root_rot_treatment">Boresha mifereji; tumia fungicide ya udongo.</string>

    <!-- Coffee care tips -->
    <string name="tip_healthy_title">Kahawa yenye Afya</string>
    <string name="tip_healthy_desc">Mmea wa kahawa unaonekana mzima. Majani ni ya kijani kibichi.</string>
    <string name="tip_healthy_symptoms">Majani safi bila madoa au rangi isiyo ya kawaida.</string>
    <string name="tip_healthy_treatment">Endelea utunzaji wa kawaida: pumua, mbolea, na maji ya kutosha.</string>
    <string name="tip_rust_title">Kutu ya Majani ya Kahawa</string>
    <string name="tip_rust_desc">Kutu ya majani ni ugonjwa mbaya wa fangasi unaoharibu majani ya kahawa.</string>
    <string name="tip_rust_symptoms">Madoa ya unga wa njano/machungwa chini ya jani.</string>
    <string name="tip_rust_treatment">Tumia dawa za fangasi zenye shaba na ondoa majani yaliyoathirika.</string>
    <string name="tip_berry_title">Ugonjwa wa Beri ya Kahawa</string>
    <string name="tip_berry_desc">Ugonjwa wa beri huashambulia beri za kahawa moja kwa moja.</string>
    <string name="tip_berry_symptoms">Madoa meusi yaliyozama kwenye beri za kijani.</string>
    <string name="tip_berry_treatment">Tumia fungicide wakati wa kutoa maua na ukuaji wa beri.</string>
    <string name="tip_wilt_title">Mnyauko wa Kahawa</string>
    <string name="tip_wilt_desc">Mnyauko wa kahawa huua mmea mzima kwa muda mfupi.</string>
    <string name="tip_wilt_symptoms">Matawi kunyauka ghafla; mmea kukauka kutoka juu.</string>
    <string name="tip_wilt_treatment">Ng\'oa na choma mimea iliyoathirika ili kuzuia kuenea.</string>
    <string name="tip_leaf_miner_title">Mdudu Mchimbaji</string>
    <string name="tip_leaf_miner_desc">Mdudu mchimbaji huchimba ndani ya jani na kuharibu tishu.</string>
    <string name="tip_leaf_miner_symptoms">Mistari meupe zenye umbo la zigzag kwenye jani.</string>
    <string name="tip_leaf_miner_treatment">Tumia dawa za wadudu na ondoa majani yaliyoathirika.</string>
    <string name="tip_root_rot_title">Oza ya Mizizi</string>
    <string name="tip_root_rot_desc">Oza ya mizizi husababishwa na fangasi wa udongo na unyevu mwingi.</string>
    <string name="tip_root_rot_symptoms">Majani kugeuka njano na mmea kudumaa licha ya maji.</string>
    <string name="tip_root_rot_treatment">Boresha mifereji ya maji na tumia fungicide ya udongo.</string>

