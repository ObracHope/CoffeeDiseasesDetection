<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.CoffeeDiseasesDetection" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary Brand Color -->
        <item name="colorPrimary">@color/primaryGreen</item>
        <item name="colorPrimaryDark">@color/primaryGreenDark</item>
        <item name="colorPrimaryContainer">@color/primaryGreenLight</item>
        
        <!-- Secondary Brand Color -->
        <item name="colorSecondary">@color/primaryBrown</item>
        <item name="colorSecondaryContainer">@color/primaryBrownLight</item>
        
        <!-- Accent Colors -->
        <item name="colorTertiary">@color/accentYellow</item>
        
        <!-- Background Colors -->
        <item name="android:colorBackground">@color/backgroundCream</item>
        <item name="colorSurface">@color/card_background</item>
        
        <!-- Text Colors -->
        <item name="android:textColorPrimary">@color/textDark</item>
        <item name="android:textColorSecondary">@color/textMedium</item>
        
        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/primaryGreenDark</item>
        
        <!-- Font Family -->
        <item name="android:fontFamily">sans-serif</item>
        
        <!-- Card Styles -->
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
    </style>

    <style name="Theme.CoffeeDiseasesDetection" parent="Base.Theme.CoffeeDiseasesDetection">
        <item name="colorPrimary">@color/primaryGreen</item>
        <item name="colorSecondary">@color/primaryBrown</item>
        <item name="android:statusBarColor">@color/primaryGreenDark</item>
    </style>




    <!-- Modern Card Style -->
    <style name="ModernCardStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_margin">12dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:stateListAnimator">@animator/card_press_animator</item>
    </style>

    <!-- Glassmorphism Card Style -->
    <style name="GlassCardStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_margin">12dp</item>
        <item name="android:background">@drawable/bg_glass_card</item>
        <item name="android:elevation">8dp</item>
        <item name="android:clipToPadding">false</item>
        <item name="android:stateListAnimator">@animator/card_press_animator</item>
        <item name="cardBackgroundColor">#26FFFFFF</item> <!-- Uwazi wa Glass -->
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">#40FFFFFF</item> <!-- Mstari mwembamba wa kioo -->
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <!-- Premium Gradient Button -->
    <style name="GradientButtonStyle" parent="Widget.Material3.Button">
        <item name="android:background">@drawable/bg_gradient_button</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:stateListAnimator" tools:targetApi="l">@null</item>
    </style>

    <!-- Rounded Material 3 Input -->
    <style name="RoundedInputStyle" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="boxStrokeColor">@color/gradient_green_center</item>
        <item name="hintTextColor">@color/gradient_green_center</item>
    </style>

    <!-- Dashboard Styles (Legacy override) -->
    <style name="DashboardCardStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_margin">8dp</item>
        <item name="cardCornerRadius">30dp</item>
        <item name="cardElevation">10dp</item>
    </style>

    <style name="DashboardIconStyle">
        <item name="android:layout_width">56dp</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:background">@drawable/bg_text_outline</item>
        <item name="android:padding">8dp</item>
        <item name="android:tint">@android:color/white</item>
    </style>

    <style name="DashboardTextStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:background">@drawable/bg_text_outline</item>
        <item name="android:padding">4dp</item>
    </style>

    <!-- Bottom Navigation Text Styles -->
    <style name="BottomNavTextActive">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/primaryGreen</item>
    </style>

    <style name="BottomNavTextInactive">
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="BottomNavActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/primaryBrown</item>
        <item name="marginHorizontal">8dp</item>
    </style>
</resources>