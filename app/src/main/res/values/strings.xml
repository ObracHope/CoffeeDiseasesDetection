    <string name="disease_rust_desc">Coffee Leaf Rust is a fungal disease that damages leaves.</string>
    <string name="disease_berry_desc">Coffee Berry Disease affects coffee berries directly.</string>
    <string name="disease_wilt_desc">Coffee Wilt causes the plant to dry and die.</string>
    <string name="disease_leaf_miner_desc">Leaf Miner insects damage tissue inside the leaf.</string>
    <string name="disease_root_rot_desc">Root rot is caused by excess moisture or soil fungi.</string>
    <string name="disease_healthy_symptoms">Bright green leaves, no spots, strong growth.</string>
    <string name="disease_rust_symptoms">Yellow-orange spots under leaves; leaves may wilt.</string>
    <string name="disease_berry_symptoms">Dark lesions on berries; berries may dry and drop.</string>
    <string name="disease_wilt_symptoms">Leaves wilt quickly; plant collapses.</string>
    <string name="disease_leaf_miner_symptoms">White zigzag trails on leaf surface.</string>
    <string name="disease_root_rot_symptoms">Yellowing leaves despite watering; plant declines.</string>
    <string name="disease_healthy_treatment">Continue good care: pruning, fertilizer, and daily checks.</string>
    <string name="disease_rust_treatment">Use copper fungicide, remove infected leaves, improve airflow.</string>
    <string name="disease_berry_treatment">Remove infected fruit; apply fungicide during flowering.</string>
    <string name="disease_wilt_treatment">Remove infected plants; improve drainage and soil treatment.</string>
    <string name="disease_leaf_miner_treatment">Use insecticide; remove heavily infested leaves.</string>
    <string name="disease_root_rot_treatment">Improve drainage; apply soil fungicide; remove affected plants.</string>

    <!-- Coffee care tips (dashboard carousel) -->
    <string name="tip_healthy_title">Healthy Coffee</string>
    <string name="tip_healthy_desc">The coffee plant looks healthy. Leaves are bright green and vigorous.</string>
    <string name="tip_healthy_symptoms">Clean leaves with no spots or unusual discoloration.</string>
    <string name="tip_healthy_treatment">Continue regular farm care: pruning, fertilizer, and adequate water.</string>
    <string name="tip_rust_title">Coffee Leaf Rust</string>
    <string name="tip_rust_desc">Coffee Leaf Rust is a serious fungal disease affecting coffee leaves.</string>
    <string name="tip_rust_symptoms">Yellow-orange powdery spots on the underside of leaves.</string>
    <string name="tip_rust_treatment">Use copper-based fungicides and remove infected leaves.</string>
    <string name="tip_berry_title">Coffee Berry Disease</string>
    <string name="tip_berry_desc">Coffee Berry Disease attacks coffee berries directly.</string>
    <string name="tip_berry_symptoms">Dark sunken lesions on green berries.</string>
    <string name="tip_berry_treatment">Apply fungicide during flowering and early berry development.</string>
    <string name="tip_wilt_title">Coffee Wilt Disease</string>
    <string name="tip_wilt_desc">Coffee Wilt kills the whole plant within a short time.</string>
    <string name="tip_wilt_symptoms">Sudden wilting of branches; plant dries from the top down.</string>
    <string name="tip_wilt_treatment">Remove and burn infected plants to stop spread.</string>
    <string name="tip_leaf_miner_title">Leaf Miner</string>
    <string name="tip_leaf_miner_desc">Leaf Miner insects tunnel inside leaves and damage tissue.</string>
    <string name="tip_leaf_miner_symptoms">White zigzag trails visible on the leaf surface.</string>
    <string name="tip_leaf_miner_treatment">Use appropriate insecticide and remove infested leaves.</string>
    <string name="tip_root_rot_title">Root Rot</string>
    <string name="tip_root_rot_desc">Root Rot is caused by soil fungi and excess moisture.</string>
    <string name="tip_root_rot_symptoms">Yellowing leaves and plant decline despite watering.</string>
    <string name="tip_root_rot_treatment">Improve drainage and apply recommended soil fungicides.</string>

